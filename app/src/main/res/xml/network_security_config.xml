<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — enforces HTTPS for all connections.
    Cleartext (HTTP) traffic is blocked across entire app.
    Debug builds allow localhost for local dev servers only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust user-installed CA certs in debug builds only -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
